{
  "name": "lazarus-core",
  "version": "1.0.1",
  "description": "Lazarus Core ??????????????????????????????????????? Recover the Impossible",
  "main": "main/index.js",
  "homepage": "./",
  "author": {
    "name": "Lazarus Core Team"
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:renderer": "cd renderer && npm run dev",
    "build": "npm run build:renderer && electron-builder",
    "build:renderer": "cd renderer && npm run build",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "cd ../core && node-gyp rebuild"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8",
    "form-data": "^4.0.0",
    "node-addon-api": "^8.1.0",
    "node-machine-id": "^1.1.12",
    "stripe": "^15.12.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "41.2.1",
    "electron-builder": "^26.8.1",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.lazaruscore.app",
    "productName": "Lazarus Core",
    "copyright": "Copyright ???????????????????? 2025 Lazarus Core",
    "icon": "assets/icons/icon",
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "extraResources": [
      {
        "from": "../ai",
        "to": "ai"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icons/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "jolu-bot",
      "repo": "Lazarus-Core",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "electronVersion": "41.2.1",
    "directories": {
      "output": "dist-build"
    }
  }
}
